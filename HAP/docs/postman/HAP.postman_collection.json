{
  "info": {
    "name": "HAP Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@local.test\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@local.test\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/departments" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/departments", "body": { "mode": "raw", "raw": "{\n  \"name\": \"IT\",\n  \"description\": \"Infrastructure\"\n}" } } }
      ]
    },
    {
      "name": "Employees",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/employees" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/employees", "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Alex\",\n  \"lastName\": \"Morgan\",\n  \"email\": \"alex@company.test\"\n}" } } }
      ]
    },
    {
      "name": "Projects",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/projects" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Network Upgrade\"\n}" } } }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/tasks" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/tasks", "body": { "mode": "raw", "raw": "{\n  \"title\": \"Rack new switches\"\n}" } } }
      ]
    },
    {
      "name": "Requests",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/requests" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/requests", "body": { "mode": "raw", "raw": "{\n  \"title\": \"New onboarding laptop\"\n}" } } }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/inventory" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/inventory", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Laptop\",\n  \"sku\": \"LAP-001\"\n}" } } }
      ]
    },
    {
      "name": "Vendors",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/vendors" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/vendors", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Supplies\"\n}" } } }
      ]
    },
    {
      "name": "Purchase Orders",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/purchase-orders" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/purchase-orders", "body": { "mode": "raw", "raw": "{\n  \"orderNumber\": \"PO-1001\"\n}" } } }
      ]
    },
    {
      "name": "Maintenance",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/maintenance" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/maintenance", "body": { "mode": "raw", "raw": "{\n  \"description\": \"Replace toner\"\n}" } } }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        { "name": "List", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/audit-logs" } },
        { "name": "Create", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/audit-logs", "body": { "mode": "raw", "raw": "{\n  \"action\": \"create\",\n  \"entity\": \"department\",\n  \"entityId\": \"000000000000000000000000\"\n}" } } }
      ]
    }
  ]
}
